# Copy this file to `.env.local` and fill with real values.
# Never commit `.env.local` - it's ignored by git.

# Public (safe for client) Supabase settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional public site admin email
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=admin@example.com

# Secret: Service role key (server-only). Do NOT place this in client-exposed envs.
# In production, set this in your hosting provider's secret env settings only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
